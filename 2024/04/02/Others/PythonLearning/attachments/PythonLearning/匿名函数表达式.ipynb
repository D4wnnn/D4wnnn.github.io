      "qy\n"
     ]
    }
   ],
   "source": [
    "# 匿名函数表达式中的内容是否可变\n",
    "a = ['hello']\n",
    "\n",
    "b = lambda: a[0]\n",
    "print(b())\n",
    "a[0] = 'qy'\n",
    "print(b())"
   ],
