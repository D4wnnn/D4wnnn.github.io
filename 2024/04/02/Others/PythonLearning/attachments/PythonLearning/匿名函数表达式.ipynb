   "source": [
    "# 匿名函数表达式对函数再封装\n",
    "def add(i, j):\n",
    "    return i + j\n",
    "\n",
    "\n",
    "a = 1\n",
    "\n",
    "# 注意这里可以调用变量a\n",
    "b = lambda k: add(a, k)\n",
    "print(b(3))"
   ]
  },
